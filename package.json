{
  "name": "wsbb-locator",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:all": "bun run dev:api & bun run dev",
    "d": "bun run dev:all",
    "build": "bun run --cwd apps/web build",
    "preview": "bun run --cwd apps/web preview",
    "fetch": "bun run apps/api/src/scripts/fetch-thinkific.ts",
    "seed": "bun run apps/api/src/scripts/seed-db.ts"
  },
  "devDependencies": {
    "bun-types": "^1.3.14"
  }
}
