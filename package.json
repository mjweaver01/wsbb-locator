{
  "name": "wsbb-locator",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "api",
    "web"
  ],
  "scripts": {
    "dev": "bun run --cwd web dev",
    "dev:api": "bun run --cwd api dev",
    "dev:all": "bun run dev:api & bun run dev",
    "d": "bun run dev:all",
    "build": "bun run --cwd web build",
    "preview": "bun run --cwd web preview",
    "start": "bun run build && SERVE_STATIC=true bun run --cwd api start",
    "test": "bun run --cwd api test",
    "fetch": "bun run api/src/scripts/fetch-thinkific.ts",
    "resync": "bun run api/src/scripts/resync-thinkific.ts",
    "coach:add": "bun run api/src/scripts/add-manual-coach.ts",
    "coach:location": "bun run api/src/scripts/set-coach-location.ts",
    "db:sync": "bun run api/src/scripts/db-sync.ts",
    "db:pull": "railway run bash -c 'DATABASE_URL=\"$DATABASE_PUBLIC_URL\" bun run api/src/scripts/pull-prod-db.ts'",
    "format": "prettier . --write"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
