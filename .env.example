# ──────────────────────────────────────────────────────
# Thinkific (required for fetch-thinkific.ts script)
# ──────────────────────────────────────────────────────
THINKIFIC_API_KEY=your_api_key_here
THINKIFIC_SUBDOMAIN=westsidebarbell

# Fill these in after running fetch-thinkific.ts once without them.
# It will print a table of all courses so you can identify the right IDs.
THINKIFIC_LEVEL1_ID=
THINKIFIC_LEVEL2_ID=
THINKIFIC_LEVEL3_ID=

# ──────────────────────────────────────────────────────
# Database (required for seed-db.ts script)
# ──────────────────────────────────────────────────────
# SQLite for local dev:
DATABASE_URL=file:./dev.db
# Postgres for production (same Drizzle schema, no code changes needed):
# DATABASE_URL=postgres://user:password@host:5432/dbname
