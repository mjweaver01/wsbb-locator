# ──────────────────────────────────────────────────────
# Thinkific (required for fetch-thinkific.ts script)
# ──────────────────────────────────────────────────────
THINKIFIC_API_KEY=your_api_key_here
THINKIFIC_SUBDOMAIN=westside-barbell

# Fill these in after running fetch-thinkific.ts once without them.
# It will print a table of all courses so you can identify the right IDs.
THINKIFIC_LEVEL1_ID=
THINKIFIC_LEVEL2_ID=
THINKIFIC_LEVEL3_ID=
# Throttle between Thinkific paginated/profile calls (ms). Default 500.
# THINKIFIC_RATE_LIMIT_MS=500

# Monolith static serving
# When true, the API process also serves the built SPA from WEB_DIST_PATH.
# Defaults to true in production (NODE_ENV=production), false otherwise.
# SERVE_STATIC=true
# WEB_DIST_PATH=apps/web/dist

# API runtime:
# /api/coaches uses local-first source order:
#   memory -> DB cache tables -> Thinkific (if creds + DB cache empty) -> static JSON
# Optional cache TTL in milliseconds (default 3600000 / 1 hour)
COACH_CACHE_TTL_MS=3600000
# One-time login code TTL in minutes (default 15)
COACH_AUTH_CODE_TTL_MINUTES=15
# Authenticated coach session TTL in days (default 30)
COACH_SESSION_TTL_DAYS=30
# Auth session cookie name (default wsbb_coach_session)
COACH_AUTH_COOKIE_NAME=wsbb_coach_session
# Set true in HTTPS/prod deployments
# COACH_AUTH_COOKIE_SECURE=true
# Local dev only: when true, /api/coach-auth/request includes debugCode in response
# COACH_AUTH_DEBUG_EXPOSE_CODE=false
# Lax auth endpoint rate limits (per IP + email)
# COACH_AUTH_REQUEST_RATE_LIMIT_MAX=10
# COACH_AUTH_REQUEST_RATE_LIMIT_WINDOW_MS=600000
# COACH_AUTH_VERIFY_RATE_LIMIT_MAX=20
# COACH_AUTH_VERIFY_RATE_LIMIT_WINDOW_MS=600000
# CORS:
# By default, API echoes request origin (lax; good for fast setup).
# Set CORS_ENFORCE_ALLOWLIST=true to enforce CORS_ALLOWED_ORIGINS.
# CORS_ENFORCE_ALLOWLIST=false
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.up.railway.app
# Admin/internal route protection (required for refresh/resync/override/email-links/resolve-user)
# Send as `x-admin-api-key` header or `Authorization: Bearer <key>`
# COACH_ADMIN_API_KEY=replace-with-strong-random-secret

# Email delivery (default: console logs codes)
# EMAIL_PROVIDER=console
# EMAIL_PROVIDER=resend
# EMAIL_FROM=WSBB <noreply@yourdomain.com>
# RESEND_API_KEY=re_xxx

# ──────────────────────────────────────────────────────
# Overrides DB (stores only local profile overrides)
# ──────────────────────────────────────────────────────
# Optional SQLite file path for API data tables (overrides + thinkific cache)
# COACH_DATA_DB_PATH=apps/api/data/coach-data.sqlite
# Legacy alias still supported:
# COACH_OVERRIDES_DB_PATH=apps/api/data/coach-data.sqlite
# Optional Postgres connection. When set, coach profile overrides use Postgres
# (`coach_overrides`) instead of SQLite.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
# Avatar storage driver: auto | s3 | local
# auto => use S3 when AWS_* bucket creds are present, otherwise local disk.
# COACH_AVATAR_STORAGE_DRIVER=auto
# Local fallback directory when using local storage driver
# COACH_UPLOADS_DIR=apps/api/data/coach-uploads
# Max upload size in bytes (default 5 MB)
# COACH_AVATAR_MAX_BYTES=5242880
# Optional S3 key prefix inside bucket (default coach-avatars)
# COACH_AVATAR_S3_PREFIX=coach-avatars

# Railway bucket / S3-compatible credentials:
# AWS_ENDPOINT_URL=https://storage.railway.app
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET_NAME=...      # or BUCKET
# AWS_DEFAULT_REGION=auto
# AWS_S3_URL_STYLE=virtual    # use path for path-style endpoints
