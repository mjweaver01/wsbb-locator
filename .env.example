# ──────────────────────────────────────────────────────
# Thinkific (required for fetch-thinkific.ts script)
# ──────────────────────────────────────────────────────
THINKIFIC_API_KEY=your_api_key_here
THINKIFIC_SUBDOMAIN=westsidebarbell

# Fill these in after running fetch-thinkific.ts once without them.
# It will print a table of all courses so you can identify the right IDs.
THINKIFIC_LEVEL1_ID=
THINKIFIC_LEVEL2_ID=
THINKIFIC_LEVEL3_ID=

# API runtime:
# If set, /api/coaches fetches fresh data from Thinkific and caches it in-memory.
# If missing, API falls back to apps/api/data/coaches-raw.json
# Optional cache TTL in milliseconds (default 3600000 / 1 hour)
COACH_CACHE_TTL_MS=3600000

# ──────────────────────────────────────────────────────
# Overrides DB (stores only local profile overrides)
# ──────────────────────────────────────────────────────
# Optional SQLite file path (default: apps/api/data/coach-overrides.sqlite)
# COACH_OVERRIDES_DB_PATH=apps/api/data/coach-overrides.sqlite
